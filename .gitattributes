# ==============================================================================
#  Git LFS configuration
# ==============================================================================
#  Large binary artefacts (trained models, high-resolution figures, large
#  datasets) are tracked with Git LFS to keep the regular Git history lean.
#
#  Before cloning / pulling you must have Git LFS installed:
#      https://git-lfs.com
#      git lfs install
# ==============================================================================

# ── Model weights ──────────────────────────────────────────────────────────────
*.h5           filter=lfs diff=lfs merge=lfs -text
*.keras        filter=lfs diff=lfs merge=lfs -text
*.pkl          filter=lfs diff=lfs merge=lfs -text
*.joblib       filter=lfs diff=lfs merge=lfs -text
*.pt           filter=lfs diff=lfs merge=lfs -text
*.onnx         filter=lfs diff=lfs merge=lfs -text

# ── Bulky data (CSV kept as LFS only when > 50 MB — see note below) ────────────
data/raw/*.csv       filter=lfs diff=lfs merge=lfs -text
data/external/*.csv  filter=lfs diff=lfs merge=lfs -text
# NOTE: the processed 2012-2015 daily CSV is small (<1 MB) and purposefully
# tracked as plain text so contributors can `git diff` it easily.

# ── Archived datasets ──────────────────────────────────────────────────────────
*.zip          filter=lfs diff=lfs merge=lfs -text
*.tar.gz       filter=lfs diff=lfs merge=lfs -text
*.parquet      filter=lfs diff=lfs merge=lfs -text
*.feather      filter=lfs diff=lfs merge=lfs -text

# ── High-resolution figures ────────────────────────────────────────────────────
*.tif          filter=lfs diff=lfs merge=lfs -text
*.tiff         filter=lfs diff=lfs merge=lfs -text

# ── Text normalisation (cross-platform consistency) ────────────────────────────
*.py           text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.json         text eol=lf
*.toml         text eol=lf
Makefile       text eol=lf

# ── Mark notebooks as binary for cleaner diffs (use nbdime if needed) ──────────
*.ipynb        linguist-language=Python
